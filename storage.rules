rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /photos/{userId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    match /musiques/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }
  }
}